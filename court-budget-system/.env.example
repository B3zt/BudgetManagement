# กรณีใช้ PostgreSQL ทั่วไป (local, Neon, Supabase, Railway ฯลฯ):
# ใส่ค่าเดียวกันทั้งสองบรรทัดได้เลย
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/court_budget?schema=public"
DIRECT_URL="postgresql://USER:PASSWORD@localhost:5432/court_budget?schema=public"

# กรณีใช้ Prisma Postgres จาก Vercel Marketplace (Storage tab):
# Vercel จะตั้งค่า DATABASE_URL (และ DIRECT_URL ถ้ามี) ให้อัตโนมัติเมื่อกด Connect
# ไม่ต้องแก้ไขค่าด้านล่างนี้เอง ให้ดึงมาจาก Vercel ด้วยคำสั่ง: vercel env pull .env
